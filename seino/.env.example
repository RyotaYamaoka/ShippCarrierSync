# ===== 西濃運輸 マイセイノー ログイン認証情報 =====
# このファイルを .env にコピーして実値を埋める。 .env はコミットしない。

# ログインページのURL
LOGIN_URL=https://net.seino.co.jp/myseino/

# ログインID（お客様番号など・最大12桁）
LOGIN_ID=

# パスワード（最大12桁）
LOGIN_PASSWORD=

# シリアルNo（未登録デバイスからのログイン時に要求される。自動化では毎回必要）
SERIAL_NO=

# --- ダウンロード完了通知メール（SMTP）。未設定なら送信スキップ ---
SMTP_HOST=mail03.e-logit.com
SMTP_PORT=587
SMTP_USER=yamaoka@e-logit.com
SMTP_PASS=
MAIL_FROM=system_admin@shipp-app.com
MAIL_TO=yamaoka@e-logit.com

# --- 任意 ---
# 仕分コードDLページへの入口URL（通常は変更不要）
# SEINO_PROJECT_URL=announce.do?action=&displayType=2&PROJECTID=K1859401
