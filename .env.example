# ===== ヤマトビジネスメンバーズ ログイン認証情報 =====
# このファイルを .env にコピーして実値を埋める。 .env はコミットしない。

# ログインページのURL
LOGIN_URL=https://bmypage.kuronekoyamato.co.jp/bmypage/servlet/jp.co.kuronekoyamato.wur.hmp.servlet.user.HMPLGI0010JspServlet

# お客様コード（数字9〜12桁）
LOGIN_ID=

# パスワード
LOGIN_PASSWORD=

# 個人ユーザーID（任意・英数6〜20桁）
PERSONAL_ID=

# --- 任意設定 ---
# ダウンロードするマスタの種類（未指定なら通常版lzh）
#   M_PAC_DOWNLORD=通常版lzh / M_PAC_ZIP_DOWNLORD=通常版zip
#   SIMPLE_M_PAC_DOWNLORD=簡易版lzh / SIMPLE_M_PAC_ZIP_DOWNLORD=簡易版zip
#   B2_M_PAC_DOWNLORD=スマートCat zip
# DL_FUNC=M_PAC_DOWNLORD

# ブラウザを表示して動作確認したい時のみ false（EC2では未設定=headless）
# HEADLESS=false

# --- ダウンロード完了通知メール（SMTP）。未設定なら送信スキップ ---
SMTP_HOST=mail03.e-logit.com
SMTP_PORT=587
SMTP_USER=yamaoka@e-logit.com
SMTP_PASS=
MAIL_FROM=system_admin@shipp-app.com
MAIL_TO=yamaoka@e-logit.com
